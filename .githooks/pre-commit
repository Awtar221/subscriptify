#!/bin/sh
# Blocks commits that stage .env, js/config.js, or anything that looks like a
# Supabase key. Setup (once per clone): git config core.hooksPath .githooks

blocked_files=$(git diff --cached --name-only | grep -E '(^|/)\.env$|(^|/)js/config\.js$')
if [ -n "$blocked_files" ]; then
  echo "pre-commit: refusing to commit secret file(s):"
  echo "$blocked_files"
  echo "These are gitignored on purpose — unstage with: git restore --staged <file>"
  exit 1
fi

secret_hits=$(git diff --cached -U0 -- . ':!.githooks' | grep -E '^\+' | grep -E 'sb_(publishable|secret)_[A-Za-z0-9_-]+|eyJhbGciOi[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+|SUPABASE_(ANON_KEY|URL|SERVICE_ROLE_KEY)\s*=\s*['\''"][^'\''"]+['\''"]')
if [ -n "$secret_hits" ]; then
  echo "pre-commit: a staged line looks like a Supabase key/JWT:"
  echo "$secret_hits"
  echo "Move it into js/config.js (gitignored) instead of committing it inline."
  exit 1
fi

exit 0
